<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Perfil Universitario{% endblock %}</title>
        {# Enlazamos el CSS global desde la carpeta public #}
        <link rel="stylesheet" href="{{ asset('css/global.css') }}">
    </head>
    <body>
        <nav>
            <span>USFA - Symfony</span>
            <a href="/">Inicio</a>
        </nav>
        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>