<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Perfil Universitario{% endblock %}</title>
        {# Enlazamos el CSS global desde la carpeta public #}
        <link rel="stylesheet" href="{{ asset('css/global.css') }}">
    </head>
    <body>
        <nav>
        {% for message in app.flashes('success') %}
    <div style="background: #00ffcc; color: #000; padding: 10px; margin-bottom: 15px; border-radius: 4px;">
        {{ message }}
    </div>
    {% endfor %}
            <span>USFA - Symfony</span>
            <a href="/">Inicio</a>
        </nav>
        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>